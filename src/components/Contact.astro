---
const accounts = [
	{
		host: "https://msky.misononoa.cc",
		username: "@misononoa",
		text: "Misskey",
	},
	{ host: "https://x.com", username: "@misononoa", text: "x.com" },
	{ host: "mailto:me@misononoa.cc", text: "email" },
	{
		host: "https://bsky.app",
		path: "profile",
		username: "misononoa.cc",
		text: "Bluesky",
	},
	{ host: "https://mixi.social", username: "@misononoa", text: "Mixi2" },
	{
		host: "https://www.threads.net",
		username: "@misononoa",
		text: "Threads",
	},
	{ host: "https://github.com", username: "misononoa", text: "GitHub" },
];
---

<ul class="horizontal-list">
	{
		accounts.map((account) => {
			const path = [account.host];
			if (!!account.path) path.push(account.path);
			if (!!account.username) path.push(account.username);
			let text = account.text;
			if (text.match(/misskey/i)) text += "🍀";
			return <li class="item">
				<a href={path.join("/")}>{text}</a>
			</li>;
		})
	}
</ul>

<style>
	ul.horizontal-list {
		width: 100%;
		margin: 0;
		padding: 0;
		display: flex;
		justify-content: space-between;
		overflow-x: scroll;
		scrollbar-width: none;
		white-space: nowrap;
	}
	.item {
		display: inline-block;
		margin: 0 3px;
	}
</style>
